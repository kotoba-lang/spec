{:paths ["src"]
 :version "0.1.0"
 ;; kotoba-lang/spec — Layer 1 (data) of the kotoba foundational stdlib.
 ;; Data-spec validate/explain with no clojure.spec / malli dependency, so it
 ;; runs on kotoba-WASM (SCI). Zero third-party runtime deps; .cljc.
 ;; See ADR-kotoba-lang-foundational-stdlib.md.
 :deps {}
 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}}}
